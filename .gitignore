# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets.json
common_configuration.local.js

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
.idea/

# Docker
docker-compose.override.yml

# Roku streaming container's HLS output (roku-stream/, see docker-compose.yml)
stream_output/

# Roku channel package, rebuilt fresh at every server.js startup -- see server.js and
# roku-channel/README.md
roku-channel/localwx-channel.zip

# Local background-photo library (see assets/background/README.md) -- a personal
# photo collection doesn't belong in git, same reasoning as .env above. Keeps the
# folder structure itself (and its own README) tracked so it still exists after a
# fresh clone, just not anything dropped into it.
assets/background/*
!assets/background/README.md
