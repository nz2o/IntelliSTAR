# Home-screen tile icon and launch splash screen -- see images/, generated from the
# same crest as assets/logos/benefields.svg in the main app. Only used for sideloaded
# dev channels like this one (or if the Channel Store can't be reached); mm_icon_focus_hd
# and splash_screen_fhd are the two Roku actually requires, focus_fhd/splash_hd are
# included too for sharper rendering on higher-resolution devices.
mm_icon_focus_hd=pkg:/images/icon_focus_hd.png
mm_icon_focus_fhd=pkg:/images/icon_focus_fhd.png
splash_screen_hd=pkg:/images/splash_hd.png
splash_screen_fhd=pkg:/images/splash_fhd.png
