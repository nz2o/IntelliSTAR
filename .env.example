# Copy this file to .env and fill in real values. .env is gitignored and never committed.

# Port the Node server listens/publishes on.
PORT=3000

# Sent as the User-Agent header on requests to api.weather.gov, per NWS's request
# that API callers self-identify. Format: AppName (contact email or URL).
NWS_USER_AGENT=YourAppName (you@example.com)

# Hard limit (in seconds) on how often server.js will make an outbound call to NWS/
# zippopotam.us for the same piece of data (same zip code, same gridpoint, etc.) --
# see the rate limiter in NWSInterface.js. This is not a performance tweak: however
# often the app asks (every loop cycle, multiple viewers/devices pointed at this
# server), it will not call NWS more than once per this many seconds for the same
# request; everything else in between is served the last successful result. Default
# of 60 is a floor, not a target -- raise it if you want to be more conservative.
NWS_MIN_INTERVAL_SECONDS=60

# Fixed onnxruntime thread count for the self-hosted PiperTTS container (see
# piper/app.py). Default is a conservative 2. On some setups -- notably Docker
# running inside an LXC container -- onnxruntime's default auto-detected thread pool
# tries to pin threads to CPU cores using an affinity mask the container isn't
# actually allowed to set, filling the piper container's logs with
# "pthread_setaffinity_np failed ... Invalid argument" errors. Setting this
# explicitly (any positive number) avoids that entirely. Raise it on dedicated/
# beefier hardware for more synthesis throughput.
PIPER_NUM_THREADS=2

# Optional overrides for common_configuration.js's greetingText/crawlText defaults.
# Leave unset to use the defaults baked into common_configuration.js.
GREETING_TEXT=Your local forecast
CRAWL_TEXT=Sample Crawl Text

# Optional override for common_configuration.js's narrationDwellMs default (5000ms).
# Extra pause, in whole seconds, after narration finishes before the page advances.
NARRATION_DWELL_SECONDS=5

# Optional override for common_configuration.js's showFetchingMessage default (true).
# Set to "false" to hide the "Fetching current weather for..." message entirely.
SHOW_FETCHING_MESSAGE=true

# Optional override for common_configuration.js's musicDuckLevel default (0.3). How
# much to duck (reduce, not mute) background music while voice narration is speaking,
# as a fraction of the master volume -- 0 is silent, 1 leaves it at full volume
# alongside the narration. Restored to full volume when narration finishes. Does not
# apply on iOS Safari (the "Apple Mobile Device Workaround" option), which can only
# mute/unmute -- iOS ignores JS volume changes on <audio> elements, a real platform
# limitation, not something this setting can work around.
MUSIC_DUCK_LEVEL=0.3

# Startup location, used to pre-fill (and, with AUTO_START below, automatically run)
# the "Enter Zip or Airport ICAO Code" field. A 5-digit US zip code, a 3-4 character
# airport ICAO code, or the literal value AUTOMATIC to have the server geolocate its
# own public IP address and use the resulting zip code. Only takes effect the first
# time a browser is used -- once a location has been saved from a previous visit,
# that saved value takes priority. Leave unset to require the user to type one in.
DEFAULT_LOCATION=AUTOMATIC

# Optional override for common_configuration.js's alertsEnabledDefault (true).
# Whether Watch/Warning/Advisory alerts are included, before any preference has been
# saved in this browser. Set to "false" to disable.
ALERTS_ENABLED_DEFAULT=true

# Optional override for common_configuration.js's unitsDefault (US), before any
# preference has been saved in this browser. One of: US (°F/mph), Metric (°C/km/h).
UNITS_DEFAULT=US

# Optional override for common_configuration.js's musicEnabledDefault (true), before
# any preference has been saved in this browser. Set to "false" to disable background
# music by default.
MUSIC_ENABLED_DEFAULT=true

# Optional override for common_configuration.js's appleWorkaroundDefault (false),
# before any preference has been saved in this browser. Set to "true" to default the
# "Enable Workaround for Apple Mobile Devices" checkbox on (mutes instead of changing
# volume for background music, since iOS Safari does not allow JS volume control).
APPLE_WORKAROUND_DEFAULT=false

# Optional override for common_configuration.js's voiceEnabledDefault (true), before
# any preference has been saved in this browser. Set to "false" to disable PiperTTS
# voice narration by default.
VOICE_ENABLED_DEFAULT=true

# Optional override for common_configuration.js's voiceSelectDefault
# (en_US-lessac-medium). The PiperTTS voice to pre-select, if it's present in the
# voice list returned by the configured PiperTTS server (see common_configuration.js
# PiperTTS.endpoints).
VOICE_SELECT_DEFAULT=en_US-lessac-medium

# Optional override for common_configuration.js's voiceAlertsNarrationDefault (true),
# before any preference has been saved in this browser. Set to "false" to disable
# narration of alert text by default (only relevant when voice narration is enabled).
VOICE_ALERTS_NARRATION_DEFAULT=true

# Optional override for common_configuration.js's loopEnabledDefault (true), before
# any preference has been saved in this browser. Controls whether the presentation
# automatically restarts itself when it finishes, instead of stopping until someone
# clicks (or presses Enter on) the NWS logo. Set to "false" to require the click by
# default; clicking the logo still toggles it per-browser after the first visit.
LOOP_ENABLED_DEFAULT=true

# Optional override for common_configuration.js's autoStart default (false). Set to
# "true" to skip the startup "Weather Location" dialog entirely and begin the
# presentation automatically -- using a location already saved in this browser, or
# otherwise DEFAULT_LOCATION above -- as soon as the page loads, with no click required.
AUTO_START=false
